# Copy this file to .env and adjust as needed: cp .env.example .env
# main.py loads .env automatically (via python-dotenv) before the app starts.

# Signs/verifies login JWTs. Required — the app raises at login time if unset.
# Use a random value of 32+ bytes in real environments; this default is fine for local dev only.
JWT_SECRET_KEY=local-dev-secret-change-me-please-32bytes

# If all three SEED_ATTORNEY_* vars are set, an idempotent startup hook creates
# one attorney account so you can log into the internal dashboard locally.
# (Matches dev.sh's defaults, so the login works the same way whether you
# start the backend via dev.sh or by hand.)
SEED_ATTORNEY_EMAIL=attorney@example.com
SEED_ATTORNEY_PASSWORD=devpassword123
SEED_ATTORNEY_NAME=Dev Attorney

# By default (EMAIL_BACKEND unset) confirmation/notification emails are only
# logged to the console, not actually sent — see email_service.py. To send
# real email for a demo via Resend (resend.com, free tier, no SDK required):
# uncomment these three lines and fill in your own API key.
#
# EMAIL_BACKEND=resend
# RESEND_API_KEY=your-resend-api-key-here
# RESEND_FROM_ADDRESS=onboarding@resend.dev
#
# Note: without a verified sending domain on Resend, they only deliver to the
# email address on your own Resend account — fine for a local demo where
# you're submitting the lead yourself and also playing the attorney. Make
# sure ATTORNEY_NOTIFICATION_EMAIL below (and the email you type into the
# lead form) both point at that same address.
# ATTORNEY_NOTIFICATION_EMAIL=your-resend-account-email@example.com
